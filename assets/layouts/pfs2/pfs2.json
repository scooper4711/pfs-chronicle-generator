{
  "id": "pfs2",
  "description": "Pathfinder 2 Society Chronicle",
  "aspectratio": "603:783",
  "defaultChronicleLocation": "modules/pfs-chronicle-generator/assets/chronicles/pfs2/bounties/B1-TheWhitefangWyrmChronicle.pdf",
  "parameters": {
    "Event Info": {
      "event": {
        "type": "text",
        "description": "Event name",
        "example": "PaizoCon"
      },
      "eventcode": {
        "type": "text",
        "description": "Event code",
        "example": "1,234,456"
      },
      "date": {
        "type": "text",
        "description": "The date on which the game session took place",
        "example": "27.06.2020"
      },
      "gmid": {
        "type": "text",
        "description": "Gamemasters PFS ID",
        "example": 654321
      }
    },
    "Player Info": {
      "char": {
        "type": "text",
        "description": "Players character name",
        "example": "Merisiel"
      },
      "societyid": {
        "type": "text",
        "description": "Organized Play ID",
        "example": "123456"
      },
      "char_number": {
        "type": "text",
        "description": "Character number",
        "example": "2001"
      },
      "char_number_short": {
        "type": "text",
        "description": "Character number without leading digit",
        "example": "001"
      }
    },
    "Rewards": {
      "starting_xp": {
        "type": "text",
        "description": "Starting XP",
        "example": 2
      },
      "xp_gained": {
        "type": "text",
        "description": "XP Gained",
        "example": 4
      },
      "total_xp": {
        "type": "text",
        "description": "Total XP",
        "example": 6
      },
      "starting_currency": {
        "type": "text",
        "description": "Starting Currency",
        "example": "15 gp or 150 credits"
      },
      "treasure_bundle_value": {
        "type": "text",
        "description": "Currency from treasure bundles",
        "example": 42
      },
      "income_earned": {
        "type": "text",
        "description": "Income earned",
        "example": 1.8
      },
      "currency_gained": {
        "type": "text",
        "description": "Currency Gained",
        "example": "44.2 gp or 42 credits"
      },
      "currency_spent": {
        "type": "text",
        "description": "Currency Spent",
        "example": "0.5 gp or 5 credits"
      },
      "total_currency": {
        "type": "text",
        "description": "Total currency from treasure bundles and income",
        "example": "3.71 gp or 37 credits"
      }
    },
    "Checkboxes, Reputation and Items": {
      "summary_checkbox": {
        "type": "choice",
        "description": "Checkboxes in the adventure summary that should be selected",
        "choices": [
          1,
          2,
          3,
          4,
          5
        ],
        "example": "1,2,3,4,5"
      },
      "reputation": {
        "type": "multiline",
        "description": "Reputation Gained",
        "example": "Grand Archive: +4\nHorizon Hunters +2\nVerdant Wheel +2",
        "lines": 3
      },
      "strikeout_item_lines": {
        "type": "choice",
        "description": "Item line numbers that should be struk out",
        "choices": [
          1,
          2,
          3,
          4,
          5,
          6,
          7,
          8,
          9
        ],
        "example": "1,2,3,4,5,6,7,8,9"
      }
    },
    "Notes": {
      "notes": {
        "type": "multiline",
        "description": "Notes on the chronicle sheet",
        "example": "This is a player note line 1\nThis is a player note line 2\nThis is a player note line 3",
        "lines": 12
      }
    }
  },
  "canvas": {
    "page": {
      "x": 0.0,
      "y": 0.0,
      "x2": 100.0,
      "y2": 100.0
    }
  }
}