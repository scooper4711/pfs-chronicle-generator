  "defaultChronicleLocation": "modules/pfs-chronicle-generator/assets/chronicles/pfs2/bounties/B13-TheBlackwoodAbundanceChronicle.pdf",
  "parameters": {
    "Checkboxes, Reputation and Items": {
      "summary_checkbox": {
        "type": "choice",
        "description": "Checkboxes in the adventure summary that should be selected",
        "choices": [
          1,
          2,
          3,
          4,
          5
        ],
        "example": "1,2,3,4,5"
      },
      "reputation": {
        "type": "multiline",
        "description": "Reputation Gained",
        "example": "Grand Archive: +4",
        "lines": 4
      },
      "strikeout_item_lines": {
        "type": "choice",
        "description": "Item line numbers that should be struk out",
        "choices": [
          1,
          2,
          3,
          4,
          5,
          6,
          7,
          8,
          9
        ],
        "example": "1,2,3,4,5,6,7,8,9"
      }
    },
    "Rewards": {
      "starting_xp": {
        "type": "text",
        "description": "Starting XP",
        "example": 2
      },
      "xp_gained": {
        "type": "text",
        "description": "XP Gained",
        "example": 4
      },
      "total_xp": {
        "type": "text",
        "description": "Total XP",
        "example": 6
      },
      "starting_gp": {
        "type": "text",
        "description": "Starting GP",
        "example": "1cp"
      },
      "treasure_bundles_gp": {
        "type": "text",
        "description": "Gold from treasure bundles",
        "example": 23
      },
      "income_earned": {
        "type": "text",
        "description": "Income earned (gp)",
        "example": 1.8
      },
      "gp_gained": {
        "type": "text",
        "description": "GP Gained",
        "example": "44.2 gp"
      },
      "gp_spent": {
        "type": "text",
        "description": "GP Spent",
        "example": "5sp"
      },
      "total_gp": {
        "type": "text",
        "description": "Total GP from treasure bundles and income",
        "example": "3gp 7sp 1cp"
      }
    },
    "Notes": {
      "notes": {
        "type": "multiline",
        "description": "Notes on the chronicle sheet",
        "example": "This is a player note",
        "lines": 6
      }
    },
    "Event Info": {
      "event": {
        "type": "text",
        "description": "Event name",
        "example": "PaizoCon"
      },
      "eventcode": {
        "type": "text",
        "description": "Event code",
        "example": "1,234,456"
      },
      "date": {
        "type": "text",
        "description": "The date on which the game session took place",
        "example": "27.06.2020"
      },
      "gmid": {
        "type": "text",
        "description": "Gamemasters PFS ID",
        "example": 654321
      }
    },
    "Player Info": {
      "char": {
        "type": "text",
        "description": "Players character name",
        "example": "Merisiel"
      },
      "societyid": {
        "type": "text",
        "description": "Organized Play ID",
        "example": "123456"
      },
      "char_number": {
        "type": "text",
        "description": "Character number",
        "example": "2001"
      },
      "char_number_short": {
        "type": "text",
        "description": "Character number without leading digit",
        "example": "001"
      }
    }
