{{!-- Sidebar with shared fields --}}
<aside class="sidebar">
    <ol class="box-list chronicle-shared">
        <li class="box summary collapsible-section" data-section-id="event-details">
            <header class="collapsible-header" role="button" tabindex="0" 
                    aria-expanded="false" aria-controls="event-details-content">
                <span class="chevron"></span>
                <span class="section-title"><i class="fas fa-calendar-alt"></i> Session Reporting</span>
                <span class="section-summary"></span>
            </header>
            <div class="summary-data collapsible-content" id="event-details-content">
                <div class="form-group">
                    <label for="gmPfsNumber">GM PFS Number</label>
                    <input type="text" id="gmPfsNumber" name="shared.gmPfsNumber" value="{{shared.gmPfsNumber}}" data-tooltip="Your Organized Play ID number from paizo.com. This is printed on every chronicle you generate.">
                </div>
                
                <div class="form-group">
                    <label for="season">Season</label>
                    <select id="season" name="shared.seasonId" data-tooltip="Select the season or category (Bounties, Quests, Specials) that contains the scenario you ran.">
                        {{#each seasons}}
                            <option value="{{this.id}}" {{#if (eq this.id ../selectedSeasonId)}}selected{{/if}}>{{this.name}}</option>
                        {{/each}}
                    </select>
                </div>
                
                <div class="form-group">
                    <label for="layout">Scenario</label>
                    <select id="layout" name="shared.layoutId" data-tooltip="Select the specific scenario you ran. This determines the chronicle layout, item list, and adventure summary checkboxes.">
                        {{#each layoutsInSeason}}
                            <option value="{{this.id}}" {{#if (eq this.id ../selectedLayoutId)}}selected{{/if}}>{{this.description}}</option>
                        {{/each}}
                    </select>
                </div>
                
                <div class="form-group">
                    <label for="scenarioName">Event Name</label>
                    <input type="text" id="scenarioName" name="shared.scenarioName" value="{{shared.scenarioName}}" data-tooltip="The name of the event where you ran this game (e.g. your local game store name, convention name, or 'Online Play').">
                </div>
                
                <div class="form-group">
                    <label for="eventCode">Event Code</label>
                    <input type="text" id="eventCode" name="shared.eventCode" value="{{shared.eventCode}}" data-tooltip="The event code from paizo.com for this session. Create one at paizo.com under Organized Play → My Events if you don't have one yet.">
                </div>
                
                <div class="form-group">
                    <label for="eventDate">Event Date</label>
                    <input type="date" id="eventDate" name="shared.eventDate" value="{{shared.eventDate}}" data-tooltip="The date the game was played. Used on the chronicle and in the session report for paizo.com.">
                </div>
                
                <div class="form-group {{#unless chroniclePathExists}}chronicle-path-visible{{/unless}}" id="chroniclePathGroup">
                    <label for="blankChroniclePath">Chronicle PDF
                        <span class="fas fa-question-circle" data-tooltip="This module cannot distribute Paizo's chronicle PDFs due to licensing. For Seasons 5–7, the chronicle is included in the premium Foundry VTT module and will be set automatically when you select a scenario. For all other seasons, use the file picker to upload a copy of the blank chronicle PDF (or the full scenario PDF) to your Foundry server."></span>
                    </label>
                    <div class="form-fields">
                        <input type="text" id="blankChroniclePath" name="shared.blankChroniclePath" value="{{shared.blankChroniclePath}}" readonly>
                        <button type="button" class="file-picker-button" id="chroniclePathFilePicker"><i class="fas fa-folder-open" data-tooltip="Browse or upload a blank chronicle PDF"></i></button>
                    </div>
                </div>
                
                <div class="form-group reporting-flags" data-tooltip="Optional reporting flags A–D as defined by the scenario. Check the ones that apply based on the party's choices during the adventure.">
                    <label>Reporting Flags</label>
                    <div class="form-fields">
                        <label class="checkbox-label"><input type="checkbox" id="reportingA" name="shared.reportingA" {{#if shared.reportingA}}checked{{/if}}> A</label>
                        <label class="checkbox-label"><input type="checkbox" id="reportingB" name="shared.reportingB" {{#if shared.reportingB}}checked{{/if}}> B</label>
                        <label class="checkbox-label"><input type="checkbox" id="reportingC" name="shared.reportingC" {{#if shared.reportingC}}checked{{/if}}> C</label>
                        <label class="checkbox-label"><input type="checkbox" id="reportingD" name="shared.reportingD" {{#if shared.reportingD}}checked{{/if}}> D</label>
                    </div>
                </div>
            </div>
        </li>
        
        <li class="box summary collapsible-section" data-section-id="reputation">
            <header class="collapsible-header" role="button" tabindex="0" 
                    aria-expanded="false" aria-controls="reputation-content">
                <span class="chevron"></span>
                <span class="section-title"><i class="fas fa-star"></i> Reputation</span>
                <span class="section-summary"></span>
            </header>
            <div class="summary-data collapsible-content" id="reputation-content">
                <div class="form-group">
                    <label for="chosenFactionReputation">Chosen Faction
                        <span class="fas fa-question-circle" data-tooltip="Reputation awarded to each PC's primary faction. This is the standard reputation earned for completing the adventure — typically +2 for a Quest or Bounty and +4 for a Scenario. Each PC receives this amount for whichever faction they have selected on their character sheet."></span>
                    </label>
                    <select id="chosenFactionReputation" name="shared.chosenFactionReputation">
                        <option value="0" {{#if (eq shared.chosenFactionReputation 0)}}selected{{/if}}>-</option>
                        <option value="1" {{#if (eq shared.chosenFactionReputation 1)}}selected{{/if}}>+1</option>
                        <option value="2" {{#if (eq shared.chosenFactionReputation 2)}}selected{{/if}}>+2</option>
                        <option value="3" {{#if (eq shared.chosenFactionReputation 3)}}selected{{/if}}>+3</option>
                        <option value="4" {{#if (eq shared.chosenFactionReputation 4)}}selected{{/if}}>+4</option>
                        <option value="5" {{#if (eq shared.chosenFactionReputation 5)}}selected{{/if}}>+5</option>
                        <option value="6" {{#if (eq shared.chosenFactionReputation 6)}}selected{{/if}}>+6</option>
                    </select>
                </div>
                
                <div class="form-group">
                    <label for="reputation-EA">Envoy's Alliance</label>
                    <select id="reputation-EA" name="shared.reputationValues.EA" data-tooltip="Reputation earned specifically for Envoy's Alliance for completing a side-quest. Usually +2">
                        <option value="0" {{#if (eq (lookup shared.reputationValues 'EA') 0)}}selected{{/if}}>-</option>
                        <option value="1" {{#if (eq (lookup shared.reputationValues 'EA') 1)}}selected{{/if}}>+1</option>
                        <option value="2" {{#if (eq (lookup shared.reputationValues 'EA') 2)}}selected{{/if}}>+2</option>
                        <option value="3" {{#if (eq (lookup shared.reputationValues 'EA') 3)}}selected{{/if}}>+3</option>
                        <option value="4" {{#if (eq (lookup shared.reputationValues 'EA') 4)}}selected{{/if}}>+4</option>
                        <option value="5" {{#if (eq (lookup shared.reputationValues 'EA') 5)}}selected{{/if}}>+5</option>
                        <option value="6" {{#if (eq (lookup shared.reputationValues 'EA') 6)}}selected{{/if}}>+6</option>
                    </select>
                </div>
                
                <div class="form-group">
                    <label for="reputation-GA">Grand Archive</label>
                    <select id="reputation-GA" name="shared.reputationValues.GA" data-tooltip="Reputation earned specifically for Grand Archive for completing a side-quest. Usually +2">
                        <option value="0" {{#if (eq (lookup shared.reputationValues 'GA') 0)}}selected{{/if}}>-</option>
                        <option value="1" {{#if (eq (lookup shared.reputationValues 'GA') 1)}}selected{{/if}}>+1</option>
                        <option value="2" {{#if (eq (lookup shared.reputationValues 'GA') 2)}}selected{{/if}}>+2</option>
                        <option value="3" {{#if (eq (lookup shared.reputationValues 'GA') 3)}}selected{{/if}}>+3</option>
                        <option value="4" {{#if (eq (lookup shared.reputationValues 'GA') 4)}}selected{{/if}}>+4</option>
                        <option value="5" {{#if (eq (lookup shared.reputationValues 'GA') 5)}}selected{{/if}}>+5</option>
                        <option value="6" {{#if (eq (lookup shared.reputationValues 'GA') 6)}}selected{{/if}}>+6</option>
                    </select>
                </div>
                
                <div class="form-group">
                    <label for="reputation-HH">Horizon Hunters</label>
                    <select id="reputation-HH" name="shared.reputationValues.HH" data-tooltip="Reputation earned specifically for Horizon Hunters for completing a side-quest. Usually +2">
                        <option value="0" {{#if (eq (lookup shared.reputationValues 'HH') 0)}}selected{{/if}}>-</option>
                        <option value="1" {{#if (eq (lookup shared.reputationValues 'HH') 1)}}selected{{/if}}>+1</option>
                        <option value="2" {{#if (eq (lookup shared.reputationValues 'HH') 2)}}selected{{/if}}>+2</option>
                        <option value="3" {{#if (eq (lookup shared.reputationValues 'HH') 3)}}selected{{/if}}>+3</option>
                        <option value="4" {{#if (eq (lookup shared.reputationValues 'HH') 4)}}selected{{/if}}>+4</option>
                        <option value="5" {{#if (eq (lookup shared.reputationValues 'HH') 5)}}selected{{/if}}>+5</option>
                        <option value="6" {{#if (eq (lookup shared.reputationValues 'HH') 6)}}selected{{/if}}>+6</option>
                    </select>
                </div>
                
                <div class="form-group">
                    <label for="reputation-VS">Vigilant Seal</label>
                    <select id="reputation-VS" name="shared.reputationValues.VS" data-tooltip="Reputation earned specifically for Vigilant Seal for completing a side-quest. Usually +2">
                        <option value="0" {{#if (eq (lookup shared.reputationValues 'VS') 0)}}selected{{/if}}>-</option>
                        <option value="1" {{#if (eq (lookup shared.reputationValues 'VS') 1)}}selected{{/if}}>+1</option>
                        <option value="2" {{#if (eq (lookup shared.reputationValues 'VS') 2)}}selected{{/if}}>+2</option>
                        <option value="3" {{#if (eq (lookup shared.reputationValues 'VS') 3)}}selected{{/if}}>+3</option>
                        <option value="4" {{#if (eq (lookup shared.reputationValues 'VS') 4)}}selected{{/if}}>+4</option>
                        <option value="5" {{#if (eq (lookup shared.reputationValues 'VS') 5)}}selected{{/if}}>+5</option>
                        <option value="6" {{#if (eq (lookup shared.reputationValues 'VS') 6)}}selected{{/if}}>+6</option>
                    </select>
                </div>
                
                <div class="form-group">
                    <label for="reputation-RO">Radiant Oath</label>
                    <select id="reputation-RO" name="shared.reputationValues.RO" data-tooltip="Reputation earned specifically for Radiant Oath for completing a side-quest. Usually +2">
                        <option value="0" {{#if (eq (lookup shared.reputationValues 'RO') 0)}}selected{{/if}}>-</option>
                        <option value="1" {{#if (eq (lookup shared.reputationValues 'RO') 1)}}selected{{/if}}>+1</option>
                        <option value="2" {{#if (eq (lookup shared.reputationValues 'RO') 2)}}selected{{/if}}>+2</option>
                        <option value="3" {{#if (eq (lookup shared.reputationValues 'RO') 3)}}selected{{/if}}>+3</option>
                        <option value="4" {{#if (eq (lookup shared.reputationValues 'RO') 4)}}selected{{/if}}>+4</option>
                        <option value="5" {{#if (eq (lookup shared.reputationValues 'RO') 5)}}selected{{/if}}>+5</option>
                        <option value="6" {{#if (eq (lookup shared.reputationValues 'RO') 6)}}selected{{/if}}>+6</option>
                    </select>
                </div>
                
                <div class="form-group">
                    <label for="reputation-VW">Verdant Wheel</label>
                    <select id="reputation-VW" name="shared.reputationValues.VW" data-tooltip="Reputation earned specifically for Verdant Wheel for completing a side-quest. Usually +2">
                        <option value="0" {{#if (eq (lookup shared.reputationValues 'VW') 0)}}selected{{/if}}>-</option>
                        <option value="1" {{#if (eq (lookup shared.reputationValues 'VW') 1)}}selected{{/if}}>+1</option>
                        <option value="2" {{#if (eq (lookup shared.reputationValues 'VW') 2)}}selected{{/if}}>+2</option>
                        <option value="3" {{#if (eq (lookup shared.reputationValues 'VW') 3)}}selected{{/if}}>+3</option>
                        <option value="4" {{#if (eq (lookup shared.reputationValues 'VW') 4)}}selected{{/if}}>+4</option>
                        <option value="5" {{#if (eq (lookup shared.reputationValues 'VW') 5)}}selected{{/if}}>+5</option>
                        <option value="6" {{#if (eq (lookup shared.reputationValues 'VW') 6)}}selected{{/if}}>+6</option>
                    </select>
                </div>
            </div>
        </li>
        
        <li class="box summary collapsible-section" data-section-id="shared-rewards">
            <header class="collapsible-header" role="button" tabindex="0" 
                    aria-expanded="false" aria-controls="shared-rewards-content">
                <span class="chevron"></span>
                <span class="section-title"><i class="fas fa-gift"></i> Shared Rewards</span>
                <span class="section-summary"></span>
            </header>
            <div class="summary-data collapsible-content" id="shared-rewards-content">
                <div class="form-group">
                    <label for="xpEarned">
                        XP Earned
                        <span class="fas fa-question-circle" data-tooltip="Each Scenario awards 4 XP. Each Bounty or Quest (Series 1) typically awards 1 XP, while each Series 2 Quest (#14 and up) typically awards 2 XP."></span>
                    </label>
                    <select id="xpEarned" name="shared.xpEarned">
                        <option value="1" {{#if (eq shared.xpEarned 1)}}selected{{/if}}>Bounty or Series 1 Quest (1 XP)</option>
                        <option value="2" {{#if (eq shared.xpEarned 2)}}selected{{/if}}>Quest (2 XP)</option>
                        <option value="4" {{#if (or (eq shared.xpEarned 4) (not shared.xpEarned))}}selected{{/if}}>Scenario (4 XP)</option>
                    </select>
                </div>
                
                <div class="form-group">
                    <label for="treasureBundles">
                        Treasure
                        <span class="fas fa-question-circle" data-tooltip="At the end of a scenario, the GM counts the Treasure Bundles (TB) the party found. The value of a Treasure Bundle depends on the level of the character earning it. Most scenarios are designed to award 8 Treasure Bundles, with 2 bonus Treasure Bundles available through exceptional play."></span>
                        </label>
                    <select id="treasureBundles" name="shared.treasureBundles">
                        <option value="0" {{#if (eq shared.treasureBundles 0)}}selected{{/if}}>-</option>
                        <option value="2.5" {{#if (eq shared.treasureBundles 2.5)}}selected{{/if}}>2.5 TB (Series 1 Quest)</option>
                        <option value="3" {{#if (eq shared.treasureBundles 3)}}selected{{/if}}>3 TB</option>
                        <option value="4" {{#if (eq shared.treasureBundles 4)}}selected{{/if}}>4 TB</option>
                        <option value="5" {{#if (eq shared.treasureBundles 5)}}selected{{/if}}>5 TB</option>
                        <option value="6" {{#if (eq shared.treasureBundles 6)}}selected{{/if}}>6 TB</option>
                        <option value="7" {{#if (eq shared.treasureBundles 7)}}selected{{/if}}>7 TB</option>
                        <option value="8" {{#if (eq shared.treasureBundles 8)}}selected{{/if}}>8 TB</option>
                        <option value="9" {{#if (eq shared.treasureBundles 9)}}selected{{/if}}>9 TB</option>
                        <option value="10" {{#if (eq shared.treasureBundles 10)}}selected{{/if}}>10 TB</option>
                    </select>
                </div>
                
                <div class="form-group">
                    <label>
                        Downtime Days
                        <i class="fas fa-question-circle" data-tooltip="Scenarios and Quests grant two days of Downtime per XP earned. Bounties are missions the PC undertakes during their Downtime and thus grant no Downtime."></i>
                    </label>
                    <div class="downtime-days-value">0</div>
                    <input type="hidden" id="downtimeDays" name="shared.downtimeDays" value="{{shared.downtimeDays}}">
                </div>
            </div>
        </li>
        
        <li class="box summary collapsible-section" data-section-id="adventure-summary">
            <header class="collapsible-header" role="button" tabindex="0" 
                    aria-expanded="true" aria-controls="adventure-summary-content">
                <span class="chevron"></span>
                <span class="section-title"><i class="fas fa-list-check"></i> Adventure Summary</span>
            </header>
            <div class="summary-data collapsible-content" id="adventure-summary-content">
                <div class="checkbox-choices">
                    {{!-- Will be populated dynamically based on layout --}}
                </div>
            </div>
        </li>
        
        <li class="box summary collapsible-section" data-section-id="items-to-strike-out">
            <header class="collapsible-header" role="button" tabindex="0" 
                    aria-expanded="true" aria-controls="items-to-strike-out-content">
                <span class="chevron"></span>
                <span class="section-title"><i class="fas fa-strikethrough"></i> Items to Strike Out <span class="fas fa-question-circle" data-tooltip="The GM must cross off the high level range items on the Chronicle Sheet if the party did not play in the high level range. The GM also must cross off items that the PCs did not encounter."></span></span>
            </header>
            <div class="summary-data collapsible-content" id="items-to-strike-out-content">
                <div class="strikeout-choices">
                    {{!-- Will be populated dynamically based on layout --}}
                </div>
            </div>
        </li>
    </ol>
</aside>

{{!-- Main content area with character-specific fields --}}
<section class="content">
    {{!-- Validation error summary panel --}}
    <div class="validation-errors" id="validationErrors" style="display: none;">
        <h4>Please correct the following errors:</h4>
        <ul id="validationErrorList"></ul>
    </div>
    
    {{!-- Actions section --}}
    <div class="actions-section">
        <h3><i class="fas fa-bolt"></i> Actions</h3>
        <div class="buttons">
            <button type="submit" id="generateChronicles" class="icon fa-solid fa-file-pdf" data-tooltip aria-label="Generate Chronicles"></button>
            <button type="button" id="exportChronicles" class="icon fa-solid fa-download" data-tooltip aria-label="Download Archive of Party Chronicles" {{#unless hasChronicleZip}}disabled{{/unless}}></button>
            <button type="button" id="copySessionReport" class="icon fa-solid fa-clipboard" data-tooltip aria-label="Copy Session Report"></button>
            <button type="button" id="clearData" class="icon fa-solid fa-trash" data-tooltip aria-label="Clear Data"></button>
        </div>
    </div>
    
    <header class="content-header">
        <h3><i class="fas fa-users"></i> Character-Specific Information</h3>
    </header>
    
    <div class="activities">
        {{!-- GM Character Drop Zone / Section --}}
        {{#if gmCharacter}}
            <section class="member-activity gm-character-section" id="gmCharacterSection" data-character-id="{{gmCharacter.id}}">
                <div class="character-info">
                    <div class="actor-image">
                        <img class="actor-link" src="{{gmCharacter.img}}" alt="{{gmCharacter.name}}">
                    </div>
                    <div class="character-identity">
                        <div class="character-name">
                            {{gmCharacter.name}}
                            <span class="gm-credit-label">GM Credit</span>
                        </div>
                        <div class="character-society-id">{{#if gmCharacter.playerNumber}}{{gmCharacter.playerNumber}}-{{gmCharacter.characterNumber}}{{else}}<em>No Society ID</em>{{/if}}</div>
                        <div class="character-level">Level {{gmCharacter.level}}</div>
                        <div class="character-faction" id="factionDisplay-{{gmCharacter.id}}">{{#if gmCharacter.faction}}{{gmCharacter.faction}}{{else}}<em>No Faction</em>{{/if}}</div>
                    </div>
                    <button type="button" id="clearGmCharacter" class="gm-clear-button" data-tooltip="Remove GM character assignment">
                        <i class="fas fa-trash-can"></i>
                    </button>
                    {{!-- Hidden fields to preserve data --}}
                    <input type="hidden" id="gmCharacterActorId" name="shared.gmCharacterActorId" value="{{gmCharacter.id}}">
                    <input type="hidden" name="characters.{{gmCharacter.id}}.characterName" value="{{gmCharacter.name}}">
                    <input type="hidden" name="characters.{{gmCharacter.id}}.playerNumber" value="{{gmCharacter.playerNumber}}">
                    <input type="hidden" name="characters.{{gmCharacter.id}}.characterNumber" value="{{gmCharacter.characterNumber}}">
                    <input type="hidden" name="characters.{{gmCharacter.id}}.level" value="{{gmCharacter.level}}">
                </div>

                <div class="character-fields">
                    {{!-- Earned Income Section --}}
                    <div class="earned-income-section">
                        <div class="form-group">
                            <label for="taskLevel-{{gmCharacter.id}}">
                                Task Level
                                <span class="fas fa-question-circle" data-tooltip="The default task level in PFS is PC Level - 2 (minimum of 0).<br/>Select '-' if the character chose not to earn income, e.g. the chronicle won't be immediately applied or the PC will be doing a different downtime activity. <br/>PC Level - 1 or PC Level may be used if the character has a feat or boon that allows it. <br/><em style='font-size: 0.9em;'>Note: PCs with infamy are treated as one level lower (PC Level - 3).</em>"></span>
                            </label>
                            <select id="taskLevel-{{gmCharacter.id}}" name="characters.{{gmCharacter.id}}.taskLevel" data-character-level="{{gmCharacter.level}}">
                                {{#each (calculateTaskLevelOptions gmCharacter.level (lookup gmCharacterFields 'taskLevel'))}}
                                    <option value="{{value}}" {{#if selected}}selected{{/if}}>
                                        {{label}}
                                    </option>
                                {{/each}}
                            </select>
                        </div>

                        <div class="form-group">
                            <label for="successLevel-{{gmCharacter.id}}"><i class="fas fa-dice-d20"></i> Success Level</label>
                            <select id="successLevel-{{gmCharacter.id}}" name="characters.{{gmCharacter.id}}.successLevel" data-tooltip="The result of the character's Earn Income check for downtime. Defaults to Success. This affects how much gold the character earns during downtime.">
                                <option value="critical_failure" {{#if (eq (lookup gmCharacterFields 'successLevel') 'critical_failure')}}selected{{/if}}>Critical Failure</option>
                                <option value="failure" {{#if (eq (lookup gmCharacterFields 'successLevel') 'failure')}}selected{{/if}}>Failure</option>
                                <option value="success" {{#if (or (eq (lookup gmCharacterFields 'successLevel') 'success') (not (lookup gmCharacterFields 'successLevel')))}}selected{{/if}}>Success</option>
                                <option value="critical_success" {{#if (eq (lookup gmCharacterFields 'successLevel') 'critical_success')}}selected{{/if}}>Critical Success</option>
                            </select>
                        </div>

                        <div class="form-group">
                            <label for="proficiencyRank-{{gmCharacter.id}}">
                                <i class="fas fa-medal"></i> Skill Rank
                                <span class="fas fa-question-circle" data-tooltip="For most PCs, Downtime will be spent Earning Income by rolling a <b>Crafting</b>, <b>Performance</b>, or <b>Lore</b> check."></span>
                            </label>
                            <select id="proficiencyRank-{{gmCharacter.id}}" name="characters.{{gmCharacter.id}}.proficiencyRank">
                                <option value="trained" {{#if (eq (lookup gmCharacterFields 'proficiencyRank') 'trained')}}selected{{/if}}>Trained</option>
                                <option value="expert" {{#if (eq (lookup gmCharacterFields 'proficiencyRank') 'expert')}}selected{{/if}}>Expert</option>
                                <option value="master" {{#if (eq (lookup gmCharacterFields 'proficiencyRank') 'master')}}selected{{/if}}>Master</option>
                                <option value="legendary" {{#if (eq (lookup gmCharacterFields 'proficiencyRank') 'legendary')}}selected{{/if}}>Legendary</option>
                            </select>
                        </div>

                        <div class="form-group">
                            <label><i class="fas fa-coins"></i> Earned Income</label>
                            <div class="earned-income-value" data-tooltip="Calculated from Task Level, Success Level, Proficiency Rank, and Downtime Days.">0.00 gp</div>
                            <input type="hidden" name="characters.{{gmCharacter.id}}.earnedIncome" value="0" class="earned-income-hidden">
                        </div>
                    </div>

                    {{!-- Treasure Bundle Value display --}}
                    <div class="form-group">
                        <label><i class="fas fa-treasure-chest"></i> Treasure Bundles</label>
                        <div class="treasure-bundle-value" data-tooltip="Calculated from shared Treasure Bundles field. Each TB is worth {{getTreasureBundleValue gmCharacter.level}} gp at level {{gmCharacter.level}}.">0.00 gp</div>
                    </div>

                    <div class="form-group">
                        <label for="currencySpent-{{gmCharacter.id}}"><i class="fas fa-money-bill-wave"></i> Currency Spent</label>
                        <input type="number" id="currencySpent-{{gmCharacter.id}}" name="characters.{{gmCharacter.id}}.currencySpent" value="{{#if gmCharacterFields}}{{lookup gmCharacterFields 'currencySpent'}}{{else}}0{{/if}}" step="0.01" data-tooltip="Optionally record currency spent during the adventure. If left at zero, the field will be left blank for the player to fill in.">
                    </div>

                    <div class="form-group full-width">
                        <label for="notes-{{gmCharacter.id}}" data-tooltip="GMs are encouraged to add notes to Chronicles about interesting events that occur during the adventure."><i class="fas fa-note-sticky"></i> Notes:</label>
                        <textarea id="notes-{{gmCharacter.id}}" name="characters.{{gmCharacter.id}}.notes" rows="3">{{#if gmCharacterFields}}{{lookup gmCharacterFields 'notes'}}{{/if}}</textarea>
                    </div>

                    <div class="form-group">
                        <label class="checkbox-label" data-tooltip="Check this if the player has already played this scenario and is using a replay credit. This is included in the session report for paizo.com.">
                            <input type="checkbox" name="characters.{{gmCharacter.id}}.consumeReplay"
                                {{#if (lookup gmCharacterFields 'consumeReplay')}}checked{{/if}}>
                            Consume Replay
                        </label>
                    </div>
                </div>
            </section>
        {{else}}
            <div class="gm-character-drop-zone" id="gmCharacterDropZone">
                <i class="fas fa-user-shield"></i>
                <p>Drop an actor here to assign a GM credit character</p>
            </div>
        {{/if}}

        {{#each partyMembers}}
            <section class="member-activity" data-character-id="{{this.id}}">
                <div class="character-info">
                    <div class="actor-image">
                        <img class="actor-link" src="{{this.img}}" alt="{{this.name}}">
                    </div>
                    <div class="character-identity">
                        <div class="character-name">{{this.name}}</div>
                        <div class="character-society-id">{{#if this.playerNumber}}{{this.playerNumber}}-{{this.characterNumber}}{{else}}<em>No Society ID</em>{{/if}}</div>
                        <div class="character-level">Level {{this.level}}</div>
                        <div class="character-faction" id="factionDisplay-{{this.id}}">{{#if this.faction}}{{this.faction}}{{else}}<em>No Faction</em>{{/if}}</div>
                    </div>
                    {{!-- Hidden fields to preserve data --}}
                    <input type="hidden" name="characters.{{this.id}}.characterName" value="{{this.name}}">
                    <input type="hidden" name="characters.{{this.id}}.playerNumber" value="{{this.playerNumber}}">
                    <input type="hidden" name="characters.{{this.id}}.characterNumber" value="{{this.characterNumber}}">
                    <input type="hidden" name="characters.{{this.id}}.level" value="{{this.level}}">
                </div>
                
                <div class="character-fields">
                    {{!-- Earned Income Section --}}
                    <div class="earned-income-section">
                        <div class="form-group">
                            <label for="taskLevel-{{this.id}}">
                                Task Level
                                <span class="fas fa-question-circle" data-tooltip="The default task level in PFS is PC Level - 2 (minimum of 0).<br/>Select '-' if the character chose not to earn income, e.g. the chronicle won't be immediately applied or the PC will be doing a different downtime activity. <br/>PC Level - 1 or PC Level may be used if the character has a feat or boon that allows it. <br/><em style='font-size: 0.9em;'>Note: PCs with infamy are treated as one level lower (PC Level - 3).</em>"></span>
                            </label>
                            <select id="taskLevel-{{this.id}}" name="characters.{{this.id}}.taskLevel" data-character-level="{{this.level}}">
                                {{#each (calculateTaskLevelOptions this.level (lookup (lookup ../savedData.characters this.id) 'taskLevel'))}}
                                    <option value="{{value}}" {{#if selected}}selected{{/if}}>
                                        {{label}}
                                    </option>
                                {{/each}}
                            </select>
                        </div>
                        
                        <div class="form-group">
                            <label for="successLevel-{{this.id}}"><i class="fas fa-dice-d20"></i> Success Level</label>
                            <select id="successLevel-{{this.id}}" name="characters.{{this.id}}.successLevel" data-tooltip="The result of the character's Earn Income check for downtime. Defaults to Success. This affects how much gold the character earns during downtime.">
                                <option value="critical_failure" {{#if (eq (lookup (lookup ../savedData.characters this.id) 'successLevel') 'critical_failure')}}selected{{/if}}>Critical Failure</option>
                                <option value="failure" {{#if (eq (lookup (lookup ../savedData.characters this.id) 'successLevel') 'failure')}}selected{{/if}}>Failure</option>
                                <option value="success" {{#if (or (eq (lookup (lookup ../savedData.characters this.id) 'successLevel') 'success') (not (lookup (lookup ../savedData.characters this.id) 'successLevel')))}}selected{{/if}}>Success</option>
                                <option value="critical_success" {{#if (eq (lookup (lookup ../savedData.characters this.id) 'successLevel') 'critical_success')}}selected{{/if}}>Critical Success</option>
                            </select>
                        </div>
                        
                        <div class="form-group">
                            <label for="proficiencyRank-{{this.id}}">
                                <i class="fas fa-medal"></i> Skill Rank
                                <span class="fas fa-question-circle" data-tooltip="For most PCs, Downtime will be spent Earning Income by rolling a <b>Crafting</b>, <b>Performance</b>, or <b>Lore</b> check."></span>
                            </label>
                            <select id="proficiencyRank-{{this.id}}" name="characters.{{this.id}}.proficiencyRank">
                                <option value="trained" {{#if (eq (lookup (lookup ../savedData.characters this.id) 'proficiencyRank') 'trained')}}selected{{/if}}>Trained</option>
                                <option value="expert" {{#if (eq (lookup (lookup ../savedData.characters this.id) 'proficiencyRank') 'expert')}}selected{{/if}}>Expert</option>
                                <option value="master" {{#if (eq (lookup (lookup ../savedData.characters this.id) 'proficiencyRank') 'master')}}selected{{/if}}>Master</option>
                                <option value="legendary" {{#if (eq (lookup (lookup ../savedData.characters this.id) 'proficiencyRank') 'legendary')}}selected{{/if}}>Legendary</option>
                            </select>
                        </div>
                        
                        <div class="form-group">
                            <label><i class="fas fa-coins"></i> Earned Income</label>
                            <div class="earned-income-value" data-tooltip="Calculated from Task Level, Success Level, Proficiency Rank, and Downtime Days.">0.00 gp</div>
                            <input type="hidden" name="characters.{{this.id}}.earnedIncome" value="0" class="earned-income-hidden">
                        </div>
                    </div>
                    
                    {{!-- Treasure Bundle Value display (read-only, calculated from treasure bundles × level) --}}
                    <div class="form-group">
                        <label><i class="fas fa-treasure-chest"></i> Treasure Bundles</label>
                        <div class="treasure-bundle-value" data-tooltip="Calculated from shared Treasure Bundles field. Each TB is worth {{getTreasureBundleValue this.level}} gp at level {{this.level}}.">0.00 gp</div>
                    </div>
                    
                    <div class="form-group">
                        <label for="currencySpent-{{this.id}}"><i class="fas fa-money-bill-wave"></i> Currency Spent</label>
                        <input type="number" id="currencySpent-{{this.id}}" name="characters.{{this.id}}.currencySpent" value="{{#if (lookup ../savedData.characters this.id)}}{{lookup (lookup ../savedData.characters this.id) 'currencySpent'}}{{else}}0{{/if}}" step="0.01" data-tooltip="Optionally record currency spent during the adventure. If left at zero, the field will be left blank for the player to fill in.">
                    </div>
                    
                    <div class="form-group full-width">
                        <label for="notes-{{this.id}}" data-tooltip="GMs are encouraged to add notes to Chronicles about interesting events that occur during the adventure."><i class="fas fa-note-sticky"></i> Notes:</label>
                        <textarea id="notes-{{this.id}}" name="characters.{{this.id}}.notes" rows="3">{{#if (lookup ../savedData.characters this.id)}}{{lookup (lookup ../savedData.characters this.id) 'notes'}}{{/if}}</textarea>
                    </div>
                    
                    <div class="form-group">
                        <label class="checkbox-label" data-tooltip="Check this if the player has already played this scenario and is using a replay credit. This is included in the session report for paizo.com.">
                            <input type="checkbox" name="characters.{{this.id}}.consumeReplay"
                                {{#if (lookup (lookup ../savedData.characters this.id) 'consumeReplay')}}checked{{/if}}>
                            Consume Replay
                        </label>
                    </div>
                </div>
            </section>
        {{/each}}
    </div>
</section>
